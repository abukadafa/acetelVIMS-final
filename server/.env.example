# ================================================================
# ACETEL VIMS — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================================

# --- Application ---
NODE_ENV=development
PORT=5000

# --- MongoDB ---
# Use MongoDB Atlas for production: https://www.mongodb.com/atlas
# Format: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/acetel_ims

# --- JWT Secrets (use long random values in production) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_min_32_chars
COOKIE_SECRET=change_me_to_a_cookie_signing_secret

# --- Admin Credentials (auto-created on first boot) ---
ADMIN_EMAIL=admin@acetel.ng
ADMIN_PASSWORD=ChangeMe@2024!

# Uncomment to reset admin password on next boot (recovery only — then remove it)
# RESET_ADMIN=true

# --- Frontend URL (used for CORS) ---
# Development:
FRONTEND_URL=http://localhost:5173
# Production (set to your Render URL):
# FRONTEND_URL=https://acetel-vims.onrender.com

# --- Google Gemini AI (optional — AI features disabled if missing) ---
GEMINI_API_KEY=

# --- Email / SMTP (optional — monitoring email alerts disabled if missing) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
