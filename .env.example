# ACETEL VIMS — Environment Configuration Example

# Database
# For Render: use the MONGO_URI from your MongoDB service
MONGO_URI=mongodb://localhost:27017/acetel_vims

# Authentication
# Secrets used for JWT signing and cookie encryption
JWT_SECRET=acetel_ims_secure_secret_2024
JWT_REFRESH_SECRET=acetel_ims_refresh_secret_2024
COOKIE_SECRET=acetel_vims_cookie_secret

# Networking
# Backend port (Render sets this automatically)
PORT=5000
# Frontend URL for CORS (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Admin Recovery
# Set to 'true' to reset admin password to ADMIN_PASSWORD value on startup
RESET_ADMIN=false
ADMIN_EMAIL=admin@acetel.edu.ng
ADMIN_PASSWORD=acetel_admin_password

# AI Features (Optional)
GEMINI_API_KEY=your_gemini_api_key_here

# Infrastructure
NODE_ENV=development
