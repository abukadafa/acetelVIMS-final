# ─────────────────────────────────────────────────────────────
# ACETEL IMS — Environment Configuration Template
# Copy this file to .env and fill in all values before deploying
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-domain.com

# ── Database ─────────────────────────────────────────────────
DB_USER=acetel_user
DB_PASS=change_this_strong_password
DB_NAME=acetel_ims
# For Render/Atlas — use this instead of the above three:
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/acetel?retryWrites=true&w=majority

# ── Security (generate with: openssl rand -hex 64) ───────────
JWT_SECRET=replace_with_64_char_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_string
COOKIE_SECRET=replace_with_another_64_char_hex_string

# ── Admin Account ─────────────────────────────────────────────
ADMIN_EMAIL=admin@your-institution.edu.ng
ADMIN_PASSWORD=StrongPassword@#2025!

# ── Email (Gmail SMTP with App Password) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx   # 16-char Gmail App Password

# ── WhatsApp (Twilio — optional, activates WA notifications) ─
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Sandbox or approved number

# ── AI Features (Gemini — optional) ──────────────────────────
GEMINI_API_KEY=AIzaSy...your_key_here
